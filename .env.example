# Copiez vers .env.local (ou variables Render) et renseignez :

OPENAI_API_KEY=
# Alias accepté par l’API analyse :
# OPENAI_KEY=

# Optionnel (défaut : gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# MongoDB Atlas — si défini, persistance dans les collections (sinon data/store.json)
# Exemple : mongodb+srv://USER:PASS@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# Nom exact de la base Atlas (sensible à la casse), ex. LUMEN
# MONGODB_DB=LUMEN

# ── PayDunya (checkout + IPN)
# PRODUCTION : clés « live » du même parcours Integration API + PAYDUNYA_MODE=live
# (sans préfixe test_private_ sur la clé privée). Les clés TEST/sandbox exigent PAYDUNYA_MODE=test.
#
# Clés depuis https://paydunya.com/integration-setups
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
# test (sandbox) | live (production). Absent = test par défaut dans le code.
# PAYDUNYA_MODE=live

# Taux CFA par 1 USD pour convertir les tarifs liste (défaut 610 si absent).
# PAYDUNYA_XOF_PER_USD=610

# URL publique HTTPS utilisée pour return_url, cancel_url, callback_url et store.website_url
# (sans slash final). Obligatoire en PAYDUNYA_MODE=live : doit correspondre au domaine connu PayDunya.
# APP_BASE_URL=https://votre-domaine.tld

# Libellés boutique PayDunya
# PAYDUNYA_STORE_NAME=Lumen
# PAYDUNYA_STORE_TAGLINE=CARIPRIP program intelligence
# PAYDUNYA_STORE_LOGO_URL=
