# Copiez vers .env.local et renseignez la clé :
# OPENAI_API_KEY=sk-...
# Optionnel : OPENAI_MODEL=gpt-4o-mini

OPENAI_API_KEY=
# OPENAI_KEY=

# Optionnel (défaut : gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini

# Multi-collection backend (voir src/lib/mongo-collections.ts pour les noms exacts).

MONGODB_URI=
# Exemple local : mongodb://127.0.0.1:27017/lumen
# Atlas : mongodb+srv://USER:PASS@cluster.mongodb.net/?appName=lumen
MONGODB_URI=
# Exemple : mongodb+srv://USER:PASS@cluster.mongodb.net/?appName=lumen

# Nom de la base (ex. LUMEN)
# MONGODB_DB=LUMEN
